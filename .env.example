APP_NAME="Creator Outreach CRM"
APP_URL="https://seudominio.com"
APP_TIMEZONE="America/Sao_Paulo"

# Gere um hash com: php -r "echo password_hash('sua-senha-forte', PASSWORD_DEFAULT);"
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD_HASH=""

# mysql para Hostinger; sqlite para testes locais.
DB_CONNECTION="mysql"
DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="nome_do_banco"
DB_USERNAME="usuario_do_banco"
DB_PASSWORD="senha_do_banco"

# Use uma ou mais chaves gratuitas da YouTube Data API v3.
YOUTUBE_API_KEY=""
YOUTUBE_API_KEYS=""
YOUTUBE_PROVIDER="auto"

# Atualizacoes pelo GitHub.
GITHUB_REPO="Lhsa050/scrappingyoutube"
GITHUB_BRANCH="main"
GITHUB_TOKEN=""

# SMTP, remetente e limite de envio sao configurados no painel em Configuracoes.
