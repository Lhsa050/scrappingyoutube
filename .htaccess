Options -Indexes

DirectoryIndex index.php
RewriteEngine On

<FilesMatch "^\.env">
  Require all denied
</FilesMatch>

RedirectMatch 404 ^/(src|database|workers|storage)(/.*)?$

RewriteRule ^assets/(.*)$ public/assets/$1 [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^$ public/index.php [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php [L]
